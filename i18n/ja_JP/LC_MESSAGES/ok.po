msgid "<b style=\"color: #0078d7;\">角色</b> 和 <b style=\"color: #0078d7;\">{combo}</b> 支持输入并创建，也支持选择已有项。"
msgstr "「キャラクター」と「{combo}」は入力して作成でき、既存の項目を選択することもできます。"

msgid "Arc Key"
msgstr "アークキー"

msgid "Check Monthly Card"
msgstr "月額カード確認"

msgid "Check for monthly card to avoid interruption of tasks"
